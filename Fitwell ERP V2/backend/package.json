    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.3",
    "memorystore": "^1.6.7",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "openid-client": "^6.8.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
